{
  "name": "taskmd-web",
  "version": "0.3.0",
  "description": "Local web UI for taskmd repos (overlay; shells out to upstream taskmd CLI)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "taskmd-web": "bin/taskmd-web.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "dev:client": "vite",
    "start": "node bin/taskmd-web.mjs start",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
